{
    "name": "backend",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "build": "tsc",
        "typeorm": "node ./node_modules/typeorm/cli.js",
        "migration:generate": "npm run build && npm run typeorm -- migration:generate -d ./build/database/data-source.js ",
        "migration:run": "npm run build && npm run typeorm -- migration:run -d ./build/database/data-source.js",
        "migration:revert": "npm run build && npm run typeorm -- migration:revert -d ./build/database/data-source.js",
        "start": "node ./build/index.js",
        "dev": "nodemon --exec ts-node ./src/index.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "jsonwebtoken": "^9.0.3",
        "mysql2": "^3.19.1",
        "nodemon": "^3.1.14",
        "reflect-metadata": "^0.2.2",
        "ts-node": "^10.9.2",
        "typeorm": "^0.3.28",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3"
    }
}
