        "@reduxjs/toolkit": "^2.11.2",
        "@types/aws-sdk": "^0.0.42",
        "aws-sdk": "^1.18.0",
        "axios": "^1.15.0",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "jsonwebtoken": "^9.0.3",
        "mercadopago": "^2.12.0",
        "multer": "^2.1.1",
