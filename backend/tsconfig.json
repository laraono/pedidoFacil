{
   "compilerOptions": {
      "lib": [
         "es2021"
      ],
      "target": "es2021",
      "module": "node16",
      "moduleResolution": "node16",
      "rootDir": "./src",
      "outDir": "./build",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "sourceMap": true,
      "esModuleInterop": true,
   },
   "include": [
      "src/**/*"
   ],
   "exclude": [
      "node_modules",
      "build"
   ]
}